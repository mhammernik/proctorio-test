services:
  web:
    image: nginx:latest
    container_name: proctorio-test
    ports:
      - "80:80"
    volumes:
      - ./src:/var/www/html
      - ./nginx/default.conf:/etc/nginx/conf.d/default.conf
    depends_on:
      - php

  php:
    image: php:8.1-fpm
    container_name: php_fpm
    volumes:
      - ./src:/var/www/html
